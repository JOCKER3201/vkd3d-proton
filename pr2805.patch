     radv_32b_layout = is_radv_device(context.device) &&
-            is_vk_device_extension_supported(context.device, "VK_EXT_descriptor_buffer") &&
+            (is_vk_device_extension_supported(context.device, "VK_EXT_descriptor_buffer") ||
